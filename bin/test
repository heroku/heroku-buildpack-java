#!/usr/bin/env bash

set -euo pipefail

BUILD_DIR="${1}"
ENV_DIR="${2}"
# ARTIFACT_DIR="${3}"

BUILDPACK_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && cd .. && pwd)"

source "${BUILDPACK_DIR}/lib/output.sh"
source "${BUILDPACK_DIR}/lib/util.sh"
source "${BUILDPACK_DIR}/lib/java_properties.sh"
source "${BUILDPACK_DIR}/lib/maven.sh"

util::export_env_dir "${ENV_DIR}" "." "JAVA_OPTS|JAVA_TOOL_OPTIONS"

cd "${BUILD_DIR}"

settings_xml_opts="$(maven::settings_xml_opts "${BUILD_DIR}")"

if maven::should_use_wrapper "${BUILD_DIR}"; then
	# Intentional word splitting for settings_xml_opts
	# shellcheck disable=SC2086
	./mvnw -B ${settings_xml_opts} "${MAVEN_HEROKU_CI_GOAL:-test}"
else
	# Intentional word splitting for settings_xml_opts
	# shellcheck disable=SC2086
	mvn -B ${settings_xml_opts} "${MAVEN_HEROKU_CI_GOAL:-test}"
fi
